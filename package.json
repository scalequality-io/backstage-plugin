{
  "name": "@scalequality/backstage-plugin",
  "version": "0.1.0",
  "description": "Render ScaleQuality's measured quality signals (AI durability, engineering maturity, code maturity, tech radar) as entity cards in Backstage.",
  "keywords": ["backstage", "backstage-plugin", "scalequality", "code-quality", "ai"],
  "homepage": "https://scalequality.io",
  "repository": { "type": "git", "url": "https://github.com/scalequality-io/backstage-plugin" },
  "license": "Apache-2.0",
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "scalequality"
  },
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.esm.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "tsc": "tsc --noEmit",
    "clean": "backstage-cli package clean"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.0",
    "@backstage/core-plugin-api": "^1.12.0",
    "@backstage/plugin-catalog-react": "^3.2.0",
    "@backstage/theme": "^0.7.0",
    "react-use": "^17.5.1"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.4.5"
  },
  "files": ["dist"]
}
